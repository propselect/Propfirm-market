rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net - Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'tafareabdulmalik@gmail.com' && 
        request.auth.token.email_verified == true
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Collections ---

    // Firms: Publicly readable
    match /firms/{firmId} {
      allow read: if true;
      allow write: if isAdmin();
      
      // Reviews nested within firms
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn() && 
                      incoming().userId == request.auth.uid &&
                      incoming().rating is number && incoming().rating >= 1 && incoming().rating <= 5 &&
                      incoming().comment is string && incoming().comment.size() <= 2000 &&
                      incoming().createdAt == request.time;
        allow update: if isSignedIn() && (isAdmin() || existing().userId == request.auth.uid) &&
                      incoming().userId == existing().userId &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['comment', 'rating', 'updatedAt', 'userName']) &&
                      incoming().updatedAt == request.time;
        allow delete: if isSignedIn() && (isAdmin() || existing().userId == request.auth.uid);
      }
    }

    // Collection Group Reviews (needed for "My Reviews" page)
    match /{path=**}/reviews/{reviewId} {
      allow read: if true;
    }

    // Reports: Authenticated create, admin read/delete
    match /reports/{reportId} {
      allow create: if isSignedIn() && 
                    incoming().userId == request.auth.uid &&
                    incoming().createdAt == request.time;
      allow read, delete: if isAdmin();
    }

    // Votes
    match /votes/{voteId} {
      allow read: if true;
      allow create: if isSignedIn() && 
                    incoming().userId == request.auth.uid &&
                    voteId == request.auth.uid + "_" + incoming().firmId &&
                    incoming().createdAt == request.time;
      allow delete: if isSignedIn() && (isAdmin() || existing().userId == request.auth.uid);
    }

    // Users
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) && 
                            incoming().uid == userId &&
                            incoming().email is string;
      allow delete: if isOwner(userId) || isAdmin();
    }

    // System paths
    match /system/{doc=**} {
      allow read: if true;
    }
    match /test/connection {
      allow read: if true;
    }
  }
}
